{
  "name": "vscode-markupai",
  "displayName": "Markup AI",
  "version": "0.3.1",
  "description": "Markup AI in VS Code: a sidebar panel that checks the active document (or your selection), highlights issues in the editor, and applies suggestions inline.",
  "categories": [
    "Linters",
    "Other"
  ],
  "keywords": [
    "markup ai",
    "style guide",
    "writing",
    "linter",
    "grammar",
    "proofreading",
    "content",
    "documentation",
    "markdown",
    "dita"
  ],
  "bugs": {
    "url": "https://github.com/markupai/vscode-extension-sidebar/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/markupai/vscode-extension-sidebar"
  },
  "license": "Apache-2.0",
  "publisher": "markupai",
  "main": "./out/extension.js",
  "browser": "./out/web/extension.js",
  "scripts": {
    "compile": "node esbuild.mjs",
    "compile:production": "node esbuild.mjs --production",
    "compile:watch": "node esbuild.mjs --watch",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix",
    "package": "mkdir -p dist && vsce package --out dist/",
    "package:pre-release": "mkdir -p dist && vsce package --pre-release --out dist/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:watch": "vitest watch",
    "test:web": "vscode-test-web --extensionDevelopmentPath=. --browserType=chromium",
    "type-check": "tsc --project tsconfig.json --noEmit",
    "vscode:prepublish": "npm run compile:production",
    "watch": "npm run compile:watch"
  },
  "contributes": {
    "views": {
      "markupai-sidebar": [
        {
          "id": "markupai.sidebar",
          "name": "Sidebar",
          "type": "webview",
          "contextualTitle": "Markup AI Sidebar"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "markupai-sidebar",
          "title": "Markup AI",
          "icon": "assets/markup-icon-activitybar.svg"
        }
      ]
    }
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "dependencies": {
    "@markupai/format-offset-mapper": "^1.1.8",
    "@markupai/sidebar-adapter": "^1.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.4",
    "@types/vscode": "^1.105.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "@vscode/test-web": "^0.0.81",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "ovsx": "^1.0.2",
    "prettier": "^3.9.3",
    "prettier-plugin-packagejson": "^3.0.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "vscode": "^1.105.1"
  },
  "icon": "assets/markup-ai-icon-128.png",
  "capabilities": {
    "virtualWorkspaces": true,
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "pricing": "Free"
}
