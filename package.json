{
  "name": "vscode-markupai",
  "displayName": "MarkupAI",
  "description": "Real-time content analysis in VS Code. Ensure your writing is clear, on-brand, and compliant with instant feedback as you type.",
  "version": "0.0.1",
  "publisher": "markupai",
  "license": "Apache-2.0",
  "icon": "assets/Markup AI Icon 128.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/markupai/vscode-extension"
  },
  "engines": {
    "vscode": "^1.108.1"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "markupai-sidebar",
          "title": "MarkupAI",
          "icon": "$(checklist)"
        }
      ],
      "panel": [
        {
          "id": "markupai-panel",
          "title": "MarkupAI",
          "icon": "$(checklist)"
        }
      ]
    },
    "views": {
      "markupai-sidebar": [
        {
          "id": "markupai.folderScanner",
          "name": "Folder Scanner",
          "type": "tree",
          "contextualTitle": "MarkupAI Folder Scanner"
        }
      ],
      "markupai-panel": [
        {
          "id": "markupai.findings",
          "name": "Findings",
          "type": "tree",
          "contextualTitle": "MarkupAI Findings"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "markupai.folderScanner",
        "contents": "No folder open.\n\nOpen a folder to scan documents for writing issues.\n\n[Open Folder](command:vscode.openFolder)\n\nOr select a specific folder:\n[Select Folder](command:markupai.selectFolder)",
        "when": "workspaceFolderCount == 0"
      }
    ],
    "commands": [
      {
        "command": "markupai.checkContent",
        "title": "MarkupAI - Check Content",
        "category": "MarkupAI"
      },
      {
        "command": "markupai.toggleEnabled",
        "title": "Toggle Enable/Disable",
        "category": "MarkupAI"
      },
      {
        "command": "markupai.enableIssues",
        "title": "MarkupAI - Enable Issues",
        "category": "MarkupAI"
      },
      {
        "command": "markupai.disableIssues",
        "title": "MarkupAI - Disable Issues",
        "category": "MarkupAI"
      },
      {
        "command": "markupai.disableCategory",
        "title": "MarkupAI - Disable Category",
        "category": "MarkupAI"
      },
      {
        "command": "markupai.enableCategory",
        "title": "MarkupAI - Enable Category",
        "category": "MarkupAI"
      },
      {
        "command": "markupai.showScores",
        "title": "Show Content Scores",
        "category": "MarkupAI"
      },
      {
        "command": "markupai.configureApiToken",
        "title": "Configure API Token",
        "category": "MarkupAI"
      },
      {
        "command": "markupai.selectStyleGuide",
        "title": "Select Style Guide",
        "category": "MarkupAI"
      },
      {
        "command": "markupai.selectDialect",
        "title": "Select Dialect",
        "category": "MarkupAI"
      },
      {
        "command": "markupai.goToIssue",
        "title": "Go to Issue",
        "category": "MarkupAI"
      },
      {
        "command": "markupai.filterBySeverity",
        "title": "Filter by Severity",
        "category": "MarkupAI",
        "icon": "$(filter)"
      },
      {
        "command": "markupai.filterByCategory",
        "title": "Filter by Category",
        "category": "MarkupAI",
        "icon": "$(tag)"
      },
      {
        "command": "markupai.clearFilters",
        "title": "Clear Filters",
        "category": "MarkupAI",
        "icon": "$(clear-all)"
      },
      {
        "command": "markupai.refreshFindings",
        "title": "Refresh Findings",
        "category": "MarkupAI",
        "icon": "$(refresh)"
      },
      {
        "command": "markupai.showAllFindings",
        "title": "Show All Files",
        "category": "MarkupAI",
        "icon": "$(files)"
      },
      {
        "command": "markupai.showCurrentFileFindings",
        "title": "Show Current File Only",
        "category": "MarkupAI",
        "icon": "$(file)"
      },
      {
        "command": "markupai.selectFolder",
        "title": "Change Folder",
        "category": "MarkupAI",
        "icon": "$(folder-opened)"
      },
      {
        "command": "markupai.refreshFolderScanner",
        "title": "Refresh Folder Scanner",
        "category": "MarkupAI",
        "icon": "$(refresh)"
      },
      {
        "command": "markupai.checkAllFiles",
        "title": "Check All Files",
        "category": "MarkupAI",
        "icon": "$(run-all)"
      },
      {
        "command": "markupai.checkSelectedFiles",
        "title": "Check Selected Files",
        "category": "MarkupAI",
        "icon": "$(run)"
      },
      {
        "command": "markupai.toggleFileSelection",
        "title": "Toggle File Selection",
        "category": "MarkupAI",
        "icon": "$(check)"
      },
      {
        "command": "markupai.openFile",
        "title": "Open File",
        "category": "MarkupAI"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "markupai.refreshFindings",
          "when": "view == markupai.findings",
          "group": "navigation@1"
        },
        {
          "command": "markupai.filterBySeverity",
          "when": "view == markupai.findings",
          "group": "navigation@2"
        },
        {
          "command": "markupai.filterByCategory",
          "when": "view == markupai.findings",
          "group": "navigation@3"
        },
        {
          "command": "markupai.clearFilters",
          "when": "view == markupai.findings",
          "group": "navigation@4"
        },
        {
          "command": "markupai.showAllFindings",
          "when": "view == markupai.findings && !markupai.showAllFiles",
          "group": "navigation@5"
        },
        {
          "command": "markupai.showCurrentFileFindings",
          "when": "view == markupai.findings && markupai.showAllFiles",
          "group": "navigation@5"
        },
        {
          "command": "markupai.selectFolder",
          "when": "view == markupai.folderScanner",
          "group": "navigation@1"
        },
        {
          "command": "markupai.refreshFolderScanner",
          "when": "view == markupai.folderScanner",
          "group": "navigation@2"
        },
        {
          "command": "markupai.checkAllFiles",
          "when": "view == markupai.folderScanner",
          "group": "navigation@3"
        },
        {
          "command": "markupai.checkSelectedFiles",
          "when": "view == markupai.folderScanner",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "markupai.toggleFileSelection",
          "when": "view == markupai.folderScanner && viewItem == file",
          "group": "inline@1"
        },
        {
          "command": "markupai.toggleFileSelection",
          "when": "view == markupai.folderScanner && viewItem == file",
          "group": "1_selection@1"
        }
      ],
      "editor/context": [
        {
          "command": "markupai.checkContent",
          "group": "markupai@1",
          "when": "editorTextFocus && markupai.enabled"
        },
        {
          "command": "markupai.disableIssues",
          "group": "markupai@2",
          "when": "editorTextFocus && markupai.enabled"
        },
        {
          "command": "markupai.enableIssues",
          "group": "markupai@2",
          "when": "editorTextFocus && !markupai.enabled"
        }
      ],
      "commandPalette": [
        {
          "command": "markupai.checkContent",
          "when": "editorIsOpen"
        },
        {
          "command": "markupai.toggleEnabled"
        },
        {
          "command": "markupai.enableIssues",
          "when": "!markupai.enabled"
        },
        {
          "command": "markupai.disableIssues",
          "when": "markupai.enabled"
        },
        {
          "command": "markupai.enableCategory",
          "when": "markupai.enabled"
        },
        {
          "command": "markupai.disableCategory",
          "when": "false"
        },
        {
          "command": "markupai.showScores",
          "when": "editorIsOpen"
        },
        {
          "command": "markupai.configureApiToken"
        },
        {
          "command": "markupai.selectStyleGuide"
        },
        {
          "command": "markupai.selectDialect"
        },
        {
          "command": "markupai.goToIssue",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "MarkupAI",
      "properties": {
        "markupai.apiToken": {
          "type": "string",
          "default": "",
          "description": "Your MarkupAI API token. Get one at https://markup.ai",
          "scope": "application"
        },
        "markupai.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable MarkupAI checking"
        },
        "markupai.dialect": {
          "type": "string",
          "default": "american_english",
          "enum": [
            "american_english",
            "british_english",
            "canadian_english"
          ],
          "enumDescriptions": [
            "American English",
            "British English",
            "Canadian English"
          ],
          "description": "The language dialect to use for checking"
        },
        "markupai.styleGuide": {
          "type": "string",
          "default": "ap",
          "description": "The style guide to use. Built-in options: 'ap', 'chicago', 'microsoft', or a custom style guide ID"
        },
        "markupai.checkOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "Automatically check content when a file is opened"
        },
        "markupai.checkOnChange": {
          "type": "boolean",
          "default": false,
          "description": "Automatically re-check content when the document changes. Enable this for real-time score updates while editing. Disable to save API calls (recommended)."
        },
        "markupai.checkDelay": {
          "type": "number",
          "default": 2000,
          "description": "Delay in milliseconds before checking after a document change"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "package": "mkdir -p dist && vsce package --out dist/",
    "package:pre-release": "mkdir -p dist && vsce package --pre-release --out dist/"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.108.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0"
  },
  "dependencies": {
    "@markupai/api": "^1.5.0",
    "diff-match-patch-ts": "^0.8.0"
  }
}
